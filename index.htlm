<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Maréchal Pro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root { --blue: #007aff; --bg: #ffffff; --gray: #8e8e93; --light-gray: #f2f2f7; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); margin: 0; padding: 20px; padding-bottom: 100px; color: #000; }
        
        /* Header */
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; position: sticky; top: 0; background: white; z-index: 10; padding: 10px 0; }
        h1 { font-size: 32px; margin: 0; font-weight: 700; }
        .logo-small { height: 40px; }

        /* Grille d'albums */
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .album { display: flex; flex-direction: column; cursor: pointer; position: relative; }
        .album:active { opacity: 0.7; }
        
        .cover { 
            width: 100%; aspect-ratio: 1/1; background: var(--light-gray); 
            border-radius: 12px; display: flex; align-items: center; justify-content: center; 
            font-size: 50px; overflow: hidden; border: 1px solid #eee; margin-bottom: 8px;
        }
        .cover img { width: 100%; height: 100%; object-fit: cover; }

        .name { font-weight: 600; font-size: 15px; margin: 0; }
        .count { color: var(--gray); font-size: 13px; margin-top: 2px; }

        /* Bouton Ajouter (+) */
        .fab { 
            position: fixed; bottom: 30px; right: 30px; 
            background: var(--blue); color: white; border: none; 
            width: 65px; height: 65px; border-radius: 50%; 
            font-size: 35px; box-shadow: 0 5px 15px rgba(0,122,255,0.4);
            display: flex; align-items: center; justify-content: center; z-index: 100;
        }

        /* Formulaire invisible par défaut */
        #form-modal { 
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0,0,0,0.5); z-index: 200; align-items: center; justify-content: center;
        }
        .modal-content { background: white; padding: 25px; border-radius: 20px; width: 85%; max-width: 400px; }
        input, textarea { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box; font-size: 16px; }
        .btn-ok { background: var(--blue); color: white; border: none; width: 100%; padding: 12px; border-radius: 10px; font-weight: bold; }
    </style>
</head>
<body>

<header>
    <h1>Albums</h1>
    <img src="logo.png" class="logo-small" alt="Logo">
</header>

<div class="grid" id="mainGrid">
    </div>

<button class="fab" onclick="ouvrirModal()">+</button>

<div id="form-modal">
    <div class="modal-content">
        <h3>Nouvelle Écurie</h3>
        <input type="text" id="ecurie-nom" placeholder="Nom de l'écurie">
        <label style="font-size: 12px; color: var(--gray);">Photo (optionnel) :</label>
        <input type="file" id="ecurie-photo" accept="image/*">
        <button class="btn-ok" onclick="sauvegarderEcurie()">Enregistrer</button>
        <button style="background:none; border:none; color:red; margin-top:10px; width:100%;" onclick="fermerModal()">Annuler</button>
    </div>
</div>

<script>
    let ecuries = JSON.parse(localStorage.getItem('maréchal_data')) || [];

    function ouvrirModal() { document.getElementById('form-modal').style.display = 'flex'; }
    function fermerModal() { document.getElementById('form-modal').style.display = 'none'; }

    function sauvegarderEcurie() {
        const nom = document.getElementById('ecurie-nom').value;
        const photoInput = document.getElementById('ecurie-photo');
        
        if (!nom) return alert("Donne un nom à l'écurie !");

        let photoUrl = "";
        if (photoInput.files && photoInput.files[0]) {
            // Ici, en local, on simule l'url de l'image
            photoUrl = URL.createObjectURL(photoInput.files[0]);
        }

        ecuries.push({ nom: nom, photo: photoUrl, chevaux: 0 });
        localStorage.setItem('maréchal_data', JSON.stringify(ecuries));
        
        document.getElementById('ecurie-nom').value = "";
        fermerModal();
        afficherEcuries();
    }

    function afficherEcuries() {
        const grid = document.getElementById('mainGrid');
        grid.innerHTML = '';

        if (ecuries.length === 0) {
            grid.innerHTML = '<p style="color:gray; grid-column: 1/3; text-align:center;">Appuie sur + pour créer ta première écurie</p>';
        }

        ecuries.forEach((ecurie, index) => {
            const cover = ecurie.photo 
                ? `<img src="${ecurie.photo}">` 
                : `🏠`;

            grid.innerHTML += `
                <div class="album" onclick="alert('Bientôt : Liste des chevaux de ${ecurie.nom}')">
                    <div class="cover">${cover}</div>
                    <p class="name">${ecurie.nom}</p>
                    <p class="count">${ecurie.chevaux} chevaux</p>
                </div>
            `;
        });
    }

    // Charger les données au lancement
    afficherEcuries();
</script>

</body>
</html>
